/* ==========================================================================
   Dashboard Scoped Styles
   ========================================================================== */

.dashboard-layout {
  --primary-color: #00BCD4;
  --secondary-color: #FF5722;
  --accent-color: #FFC107;
  --sidebar-bg: #FFFFFF;
  --main-bg: #F8FAFC;
  --card-bg: #FFFFFF;
  --text-primary: #0F172A;
  --text-secondary: #64748B;
  --border-color: #E2E8F0;
  --sidebar-width: 260px;
  --right-panel-width: 320px;
  --top-bar-height: 70px;
  
  background-color: var(--main-bg);
  min-height: 100vh;
}

/* (Include Dashboard CSS logic here) */

/* Loading Screen Shared */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  width: 100%;
  background: #050505;
  color: #fff;
}

.loader {
  border: 4px solid rgba(255, 255, 255, 0.1);
  border-left-color: #00E5FF;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
