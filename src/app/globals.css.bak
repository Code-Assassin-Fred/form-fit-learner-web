@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Outfit:wght@400;600;700;800;900&display=swap');

:root {
  --background: #ffffff;
  --foreground: #171717;
}

@media (prefers-color-scheme: dark) {
  :root {
    --background: #0a0a0a;
    --foreground: #ededed;
  }
}

* {
  box-sizing: border-box;
  padding: 0;
  margin: 0;
}

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Hide scrollbars globally as requested in original CSS */
::-webkit-scrollbar {
  display: none;
}
* {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* ==========================================================================
   Landing Page Scoped Styles
   ========================================================================== */

.landing-page {
  --bg-main: #050505;
  --bg-card: #0F0F11;
  --bg-card-hover: #161619;
  --primary: #00E5FF;
  --primary-dark: #00BBD4;
  --primary-glow: rgba(0, 229, 255, 0.4);
  --secondary: #FF3D00;
  --accent: #FBBF24;
  --text-main: #F8FAFC;
  --text-muted: #94A3B8;
  --text-dark: #0f172a;
  --border-light: rgba(255, 255, 255, 0.08);
  --border-glow: rgba(255, 255, 255, 0.15);
  --glass: rgba(15, 15, 17, 0.6);
  --glass-border: rgba(255, 255, 255, 0.08);

  color: var(--text-main);
  background-color: var(--bg-main);
  width: 100%;
  min-height: 100vh;
  position: relative;
  z-index: 1;
  background-image: radial-gradient(circle at 50% 0%, rgba(0, 229, 255, 0.05) 0%, transparent 50%),
                    radial-gradient(circle at 80% 80%, rgba(255, 61, 0, 0.03) 0%, transparent 40%);
}

